<UserControl
    x:Class="MoreFlyout.Server.FlyoutControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:MoreFlyout.Server.Helpers"
    xmlns:local="using:MoreFlyout.Server"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        x:Name="RootGrid"
        Margin="0,0,0,12"
        HorizontalAlignment="Center"
        VerticalAlignment="Bottom"
        RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <TranslateTransform X="0" Y="0" />
        </Grid.RenderTransform>

        <Grid
            x:Name="IslandsGrid"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            BorderBrush="{ThemeResource FlyoutBorderThemeBrush}"
            BorderThickness="{ThemeResource FlyoutBorderThemeThickness}"
            ColumnSpacing="12"
            CornerRadius="{StaticResource OverlayCornerRadius}"
            RowSpacing="12"
            Translation="0,0,32">
            <Grid.Shadow>
                <ThemeShadow />
            </Grid.Shadow>

            <Grid x:Name="BackdropTargetGrid" CornerRadius="{StaticResource OverlayCornerRadius}">
                <SystemBackdropElement CornerRadius="{StaticResource OverlayCornerRadius}">
                    <SystemBackdropElement.SystemBackdrop>
                        <helpers:ContentBackdropHelpers />
                    </SystemBackdropElement.SystemBackdrop>
                </SystemBackdropElement>
            </Grid>

            <ContentPresenter x:Name="GridContentPresenter" />
        </Grid>
    </Grid>
</UserControl>
