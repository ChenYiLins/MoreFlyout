<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  Transparent background for flyout  -->
    <Style
        x:Key="TransparentFlyoutPresenterStyle"
        BasedOn="{StaticResource DefaultFlyoutPresenterStyle}"
        TargetType="FlyoutPresenter">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style
        x:Key="HyperlinkButtonStyle"
        BasedOn="{StaticResource DefaultHyperlinkButtonStyle}"
        TargetType="HyperlinkButton">
        <Setter Property="Background" Value="{ThemeResource SubtleFillColorTransparentBrush}" />
    </Style>

    <Style
        x:Key="HyperlinkButtonStylePointerOver"
        BasedOn="{StaticResource DefaultHyperlinkButtonStyle}"
        TargetType="HyperlinkButton">
        <Setter Property="Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
    </Style>

</ResourceDictionary>
