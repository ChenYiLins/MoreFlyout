<Page
    x:Class="MoreFlyout.Server.Views.TrayIconMenuFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:MoreFlyout.Server.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.ContextFlyout>
        <MenuFlyout>

            <MenuFlyoutItem Text="{helpers:ResourceString Name=Settings}" Command="{x:Bind ViewModel.OpenSettingsCommand}">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE713;" />
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>

            <MenuFlyoutItem Command="{x:Bind ViewModel.OpenLogFileCommand}" Text="{helpers:ResourceString Name=OpenLogFile}">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE8E5;" />
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>

            <MenuFlyoutSeparator />

            <ToggleMenuFlyoutItem IsChecked="{x:Bind ViewModel.KeyIndicatorFlyoutEnabled, Mode=TwoWay}" Text="{helpers:ResourceString Name=KeyIndicator}">
                <ToggleMenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE92E;" />
                </ToggleMenuFlyoutItem.Icon>
            </ToggleMenuFlyoutItem>

            <ToggleMenuFlyoutItem IsChecked="{x:Bind ViewModel.MediaFlyoutEnabled, Mode=TwoWay}" Text="{helpers:ResourceString Name=Media}">
                <ToggleMenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xEA69;" />
                </ToggleMenuFlyoutItem.Icon>
            </ToggleMenuFlyoutItem>

            <ToggleMenuFlyoutItem IsChecked="{x:Bind ViewModel.DarkModeFlyoutEnabled, Mode=TwoWay}" Text="{helpers:ResourceString Name=DarkMode}">
                <ToggleMenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xF08C;" />
                </ToggleMenuFlyoutItem.Icon>
            </ToggleMenuFlyoutItem>

            <MenuFlyoutSeparator />

            <MenuFlyoutItem Command="{x:Bind ViewModel.CloseCommand}" Text="{helpers:ResourceString Name=Close}">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE711;" />
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>

        </MenuFlyout>
    </Page.ContextFlyout>

</Page>
