<Page
    x:Class="MoreFlyout.Server.Views.DarkModeFlyoutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:MoreFlyout.Server.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:styles="using:MoreFlyout.Server.Styles"
    mc:Ignorable="d">

    <Page.ContextFlyout>
        <Flyout
            x:Name="PageContextFlyout"
            FlyoutPresenterStyle="{StaticResource TransparentFlyoutPresenterStyle}"
            ShouldConstrainToRootBounds="False"
            ShowMode="Transient">
            <Flyout.SystemBackdrop>
                <styles:AcrylicSystemBackdrop />
            </Flyout.SystemBackdrop>

            <Grid
                MinWidth="164"
                Padding="-8"
                ColumnSpacing="8"
                PointerEntered="DarkModeGrid_PointerEntered"
                PointerExited="DarkModeGrid_PointerExited">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <FontIcon
                    x:Name="LightDarkModeFontIcon"
                    Grid.Column="0"
                    Margin="-4"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                    Glyph="&#xE706;" />

                <TextBlock
                    x:Name="StatusTextBlock"
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Text="Light mode"
                    TextAlignment="Center" />

                <Button
                    x:Name="ToggleModeButton"
                    Grid.Column="2"
                    Height="32"
                    MinWidth="32"
                    Margin="20,0,0,0">
                    <Button.Content>
                        <FontIcon FontSize="14" Glyph="&#xE712;" />
                    </Button.Content>
                    <Button.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Command="{x:Bind ViewModel.PauseAutoSwitchCommand}" Text="{helpers:ResourceString Name=PauseAutoSwitch}" />
                            <MenuFlyoutItem Command="{x:Bind ViewModel.ToggleThemeCommand}" Text="{helpers:ResourceString Name=ToggleTheme}" />

                            <MenuFlyoutSeparator />

                            <MenuFlyoutItem Command="{x:Bind ViewModel.ForceLightThemeCommand}" Text="{helpers:ResourceString Name=ForceLightTheme}" />
                            <MenuFlyoutItem Command="{x:Bind ViewModel.ForceDarkThemeCommand}" Text="{helpers:ResourceString Name=ForceDarkTheme}" />
                        </MenuFlyout>
                    </Button.Flyout>
                </Button>
            </Grid>

        </Flyout>
    </Page.ContextFlyout>

</Page>
