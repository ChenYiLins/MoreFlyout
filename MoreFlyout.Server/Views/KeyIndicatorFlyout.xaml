<UserControl
    x:Class="MoreFlyout.Server.Views.KeyIndicatorFlyout"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:MoreFlyout.Server.Helpers.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <UserControl.Resources>
        <converters:BoolToPositiveStyleConverter
            x:Key="BoolToPositiveStyleConverter"
            NegativeStyle="{StaticResource HyperlinkButtonStylePointerOver}"
            PositiveStyle="{StaticResource HyperlinkButtonStyle}" />
    </UserControl.Resources>

    <Grid
        Width="196"
        Height="48"
        Padding="8"
        ColumnSpacing="8"
        PointerEntered="KeyIndicatorGrid_PointerEntered"
        PointerExited="KeyIndicatorGrid_PointerExited">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="48" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <HyperlinkButton
            x:Name="IconHyperlinkButton"
            Grid.Column="0"
            Width="32"
            Height="32"
            Command="{x:Bind ViewModel.ToggleLockCommand}"
            Style="{x:Bind ViewModel.IsLocked, Converter={StaticResource BoolToPositiveStyleConverter}, Mode=OneWay}">
            <FontIcon
                x:Name="StatusFontIcon"
                Margin="-4"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                Glyph="{x:Bind ViewModel.StatusGlyph, Mode=OneWay}" />
        </HyperlinkButton>

        <FontIcon
            x:Name="ModeFontIcon"
            Grid.Column="1"
            Margin="-12,2,0,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontSize="18"
            Glyph="{x:Bind ViewModel.ModeGlyph, Mode=OneWay}" />
        <TextBlock
            x:Name="StatusTextBlock"
            Grid.Column="2"
            VerticalAlignment="Center"
            Text="{x:Bind ViewModel.Status, Mode=OneWay}"
            TextAlignment="Center" />
    </Grid>

</UserControl>
