<Window
    x:Class="MoreFlyout.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="using:MoreFlyout.App.Helpers"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MoreFlyout.App.Models"
    xmlns:ui="using:CommunityToolkit.WinUI"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            BackRequested="NavViewTitleBar_BackRequested"
            IsBackButtonEnabled="{x:Bind NavigationFrame.CanGoBack, Mode=OneWay}"
            IsBackButtonVisible="True"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="NavViewTitleBar_PaneToggleRequested">
            <TitleBar.IconSource>
                <ImageIconSource ImageSource="/Assets/AppIcon.ico" />
            </TitleBar.IconSource>

        </TitleBar>

        <NavigationView
            x:Name="NavigationViewControl"
            Grid.Row="1"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            OpenPaneLength="220">

            <NavigationView.Header>
                <BreadcrumbBar x:Name="BreadcrumbBarControl" MaxWidth="{StaticResource PageContentMaxWidth}">

                    <BreadcrumbBar.ItemTemplate>
                        <DataTemplate x:DataType="models:BreadcrumbItem">
                            <BreadcrumbBarItem AutomationProperties.Name="{Binding Content}" Content="{Binding}">
                                <BreadcrumbBarItem.ContentTemplate>
                                    <DataTemplate x:DataType="models:BreadcrumbItem">
                                        <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="{Binding Content}" />
                                    </DataTemplate>
                                </BreadcrumbBarItem.ContentTemplate>
                            </BreadcrumbBarItem>
                        </DataTemplate>
                    </BreadcrumbBar.ItemTemplate>
                </BreadcrumbBar>
            </NavigationView.Header>

            <NavigationView.MenuItems>
                <NavigationViewItem
                    Content="{helpers:ResourceString Name=Home}"
                    Icon="{ui:FontIcon Glyph=&#xE80F;}"
                    Tag="Home" />

                <NavigationViewItem
                    Content="{helpers:ResourceString Name=keyIndicator}"
                    Icon="{ui:FontIcon Glyph=&#xE92E;}"
                    Tag="KeyIndicator" />
                <NavigationViewItem
                    Content="{helpers:ResourceString Name=Media}"
                    Icon="{ui:FontIcon Glyph=&#xE8D6;}"
                    Tag="Media" />
                <NavigationViewItem
                    Content="{helpers:ResourceString Name=AutoDarkMode}"
                    Icon="{ui:FontIcon Glyph=&#xE793;}"
                    Tag="DarkMode" />
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem
                    Content="{helpers:ResourceString Name=About}"
                    Icon="{ui:FontIcon Glyph=&#xE946;}"
                    Tag="About" />
            </NavigationView.FooterMenuItems>

            <Frame x:Name="NavigationFrame" />
        </NavigationView>
    </Grid>
</Window>

